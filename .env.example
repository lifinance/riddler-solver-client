# =============================================================================
# Riddler Gasless Client Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Required
# =============================================================================

# Your wallet private key (with 0x prefix)
# This wallet will sign gasless authorizations (ERC-3009 / Permit2)
PRIVATE_KEY=0xyour_private_key_here

# Riddler API bearer token
RIDDLER_API_KEY=your_api_key_here

# =============================================================================
# Optional
# =============================================================================

# SOLVER_WALLET_ADDRESS=0xe9674277E85D7e5Ddf1340Dce118D1B887BEE727

# =============================================================================
# RPC URLs (optional - defaults provided)
# =============================================================================

# ETH_SEPOLIA_RPC=https://rpc.sepolia.org
# OP_SEPOLIA_RPC=https://sepolia.optimism.io
# BASE_SEPOLIA_RPC=https://sepolia.base.org
# ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# =============================================================================
# Debug
# =============================================================================

# Set to true for verbose error output
DEBUG=false
